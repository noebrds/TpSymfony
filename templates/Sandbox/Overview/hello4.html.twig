<!DOCTYPE html>

<html lang="fr">
    <head>
        <meta charset="utf8"/>
        <title>Hello4 !</title>
    </head>
    <body>
    <h1>Bienvenue {{ prenom }}</h1>
    <p>
        Mes jeux préférés sont &nbsp;:
        <table border="1">
        <tr>
            <th>Num</th>
            <th>Jeu</th>
        </tr>
        {% set i = 1 %}
        {% for jeu in jeux %}
            <tr>
                <td>
                    {{ i }}
                </td>
                <td>
                    {{ jeu }}
                </td>
            {% set i = i+1 %}
            </tr>
        {% else %}
            Je ne préfère aucun jeu&nbsp; !
        {% endfor %}
        </table>

    </p>
    </body>
</html>